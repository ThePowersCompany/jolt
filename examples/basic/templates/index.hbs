<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}}</title>
</head>
<body>
  <main>
    <h1>{{title}}</h1>
    <p>{{message}}</p>

    <h2>Available routes</h2>
    <ul>
      {{#each routes}}
      <li><strong>{{method}}</strong> <code>{{path}}</code> - {{description}}</li>
      {{/each}}
    </ul>
  </main>
</body>
</html>
